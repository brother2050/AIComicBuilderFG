{
  "_defaultModel": "z_image_turbo_bf16.safetensors",
  "_defaultVAE": "ae.safetensors",
  "_defaultCLIP": "qwen_3_4b.safetensors",
  "_defaultLora": "pixel_art_style_z_image_turbo.safetensors",
  "_loraStrengthModel": 1.0,
  "_loraStrengthClip": 1.0,
  "1": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "__MODEL__",
      "weight_dtype": "default"
    }
  },
  "2": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "__VAE__"
    }
  },
  "3": {
    "class_type": "CLIPLoader",
    "inputs": {
      "clip_name": "__CLIP__",
      "type": "sd3"
    }
  },
  "4": {
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["1", 0],
      "clip": ["3", 0],
      "lora_name": "__LORA__",
      "strength_model": "__NUM:lora_strength_model__",
      "strength_clip": "__NUM:lora_strength_clip__"
    }
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{positive_prompt}}",
      "clip": ["4", 1]
    }
  },
  "6": {
    "class_type": "ConditioningZeroOut",
    "inputs": {
      "conditioning": ["5", 0]
    }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{negative_prompt}}",
      "clip": ["4", 1]
    }
  },
  "8": {
    "class_type": "EmptySD3LatentImage",
    "inputs": {
      "width": "__NUM:width__",
      "height": "__NUM:height__",
      "batch_size": 1
    }
  },
  "9": {
    "class_type": "ModelSamplingAuraFlow",
    "inputs": {
      "model": ["4", 0],
      "shift": 3.0
    }
  },
  "10": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "__NUM:seed__",
      "steps": "__NUM:steps__",
      "cfg": "__NUM:cfg__",
      "sampler_name": "res_multistep",
      "scheduler": "simple",
      "denoise": "__NUM:denoise__",
      "model": ["9", 0],
      "positive": ["5", 0],
      "negative": ["7", 0],
      "latent_image": ["8", 0]
    }
  },
  "11": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["10", 0],
      "vae": ["2", 0]
    }
  },
  "12": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["11", 0],
      "filename_prefix": "z_image_turbo_lora"
    }
  }
}
