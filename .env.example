# AI漫剧生成器配置

# OpenAI API (用于文本生成: 剧本解析、角色提取、分镜拆分)
OPENAI_API_KEY=sk-xxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ComfyUI API - 文生图
COMFYUI_IMAGE_API_URL=https://your-comfyui-server.app.cloudstudio.work
COMFYUI_IMAGE_WORKFLOW=image_z_image_turbo

# ComfyUI API - 图生图
COMFYUI_IMAGE_EDIT_API_URL=https://your-comfyui-server.app.cloudstudio.work
COMFYUI_IMAGE_EDIT_WORKFLOW=image_qwen_image_edit_2509

# ComfyUI API - 视频生成 (可选，单独的视频生成服务器)
COMFYUI_VIDEO_API_URL=https://your-comfyui-server.app.cloudstudio.work
COMFYUI_VIDEO_WORKFLOW=video_wan2_2_14B_i2v

# 数据目录 (上传的文件存储位置)
UPLOAD_DIR=./uploads

# 环境模式
NODE_ENV=development
