# AI漫剧生成器配置

# OpenAI API (用于文本生成)
OPENAI_API_KEY=sk-xxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ComfyUI API (用于图像和视频生成)
COMFYUI_API_URL=https://your-comfyui-server.app.cloudstudio.work
COMFYUI_IMAGE_MODEL=z_image_turbo_bf16.safetensors
COMFYUI_VIDEO_WORKFLOW=video_generation

# 数据目录
UPLOAD_DIR=./uploads

# 环境模式
NODE_ENV=development
