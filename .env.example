# AI漫剧生成器配置

# OpenAI API (用于文本生成: 剧本解析、角色提取、分镜拆分)
OPENAI_API_KEY=sk-xxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ComfyUI API (用于图像生成: 角色参考图、帧图)
COMFYUI_API_URL=https://your-comfyui-server.app.cloudstudio.work
COMFYUI_VIDEO_WORKFLOW=video_generation

# 数据目录 (上传的文件存储位置)
UPLOAD_DIR=./uploads

# 环境模式
NODE_ENV=development
